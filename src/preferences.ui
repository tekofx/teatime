<!-- Created with Cambalache 0.92.2 -->
<interface>
  <requires lib="libadwaita" version="1.2"/>
  <object class="AdwPreferencesWindow" id="preferences_window">
    <child>
      <object class="AdwPreferencesPage" id="preferences_page">
        <child>
          <object class="AdwPreferencesGroup" id="preferences_group">
            <child>
              <object class="AdwActionRow" id="action_row">
                <property name="title">Language</property>
                <child>
                  <object class="AdwComboRow" id="combo_row"/>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
